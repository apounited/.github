{
  "scripts": {
    "fmt": "bunx oxfmt",
    "postinstall": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged",
    "commit-msg": "bunx @apounited/verify-commit-msg $1"
  },
  "lint-staged": {
    "*": [
      "bunx oxfmt --no-error-on-unmatched-pattern",
      "git add"
    ]
  }
}
